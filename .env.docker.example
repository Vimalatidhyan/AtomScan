# ==============================================================================
# Technieum Docker Environment Configuration
# Copy to .env.docker and customize for your deployment
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────
# GENERAL
# ──────────────────────────────────────────────────────────────────────────
TECHNIEUM_ENV=production
TECHNIEUM_DEBUG=false
TECHNIEUM_WORKER=true

# ──────────────────────────────────────────────────────────────────────────
# API SERVER
# ──────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ──────────────────────────────────────────────────────────────────────────
# WORKER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────
TECHNIEUM_WORKER_THREADS=4
TECHNIEUM_QUEUE_SIZE=100

# ──────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────
# For SQLite (default):
DATABASE_URL=sqlite:////data/technieum.db
TECHNIEUM_DB_PATH=/data/technieum.db

# For PostgreSQL (optional):
# DATABASE_URL=postgresql://technieum:password@postgres:5432/technieum
# POSTGRES_PASSWORD=your-secure-password

# ──────────────────────────────────────────────────────────────────────────
# DATA PATHS (inside container)
# ──────────────────────────────────────────────────────────────────────────
TECHNIEUM_OUTPUT_DIR=/data/output
TECHNIEUM_LOGS_DIR=/data/logs

# ──────────────────────────────────────────────────────────────────────────
# API KEYS (required for threat intelligence features)
# ──────────────────────────────────────────────────────────────────────────
# 🔴 CRITICAL - Get these from:
# - Shodan: https://shodan.io/account/profile
SHODAN_API_KEY=

# - Censys: https://app.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# - GitHub: https://github.com/settings/tokens
GITHUB_TOKEN=

# - SecurityTrails: https://securitytrails.com/app/credentials
SECURITYTRAILS_API_KEY=

# 🟡 OPTIONAL - Threat Intelligence Enrichment:
# - NVD: https://nvd.nist.gov/
NVD_API_KEY=

# - VirusTotal: https://www.virustotal.com/gui/user/account_overview
VIRUSTOTAL_API_KEY=

# - GreyNoise: https://www.greynoise.io/
GREYNOISE_API_KEY=

# - AbuseIPDB: https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# - AlienVault OTX: https://otx.alienvault.com/
OTX_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# SCANNING CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────
# Timeouts (in seconds)
TECHNIEUM_WHOIS_TIMEOUT=60
TECHNIEUM_SUBFINDER_TIMEOUT=900
TECHNIEUM_HTTPX_TIMEOUT=15
TECHNIEUM_HTTPX_RUN_TIMEOUT=3600
TECHNIEUM_DNSX_TIMEOUT=1800
TECHNIEUM_NUCLEI_TIMEOUT=3600
TECHNIEUM_FFUF_TIMEOUT=1800
TECHNIEUM_SQLMAP_TIMEOUT=1800

# Feature Flags
TECHNIEUM_NUCLEI_UPDATE=false          # Update Nuclei templates (takes time)
TECHNIEUM_CONTINUE_ON_FAIL=true        # Continue if a tool fails
TECHNIEUM_SKIP_KNOWN_BROKEN_TOOLS=false # Skip known broken tools (ffuf)

# ──────────────────────────────────────────────────────────────────────────
# REDIS (optional - for caching/queue)
# ──────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=technieum-redis
REDIS_DB=0

# ──────────────────────────────────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ──────────────────────────────────────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────────────────────────────────────
# JWT Secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=your-super-secret-jwt-key-change-this

# API Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ──────────────────────────────────────────────────────────────────────────
# NGINX (if using reverse proxy)
# ──────────────────────────────────────────────────────────────────────────
NGINX_SERVER_NAME=localhost
NGINX_SSL_ENABLED=false
NGINX_SSL_CERT=/etc/nginx/certs/server.crt
NGINX_SSL_KEY=/etc/nginx/certs/server.key

# ──────────────────────────────────────────────────────────────────────────
# MONITORING & TELEMETRY
# ──────────────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9000
SENTRY_DSN=                            # Optional: Sentry error tracking

# ──────────────────────────────────────────────────────────────────────────
# NOTIFICATION WEBHOOKS
# ──────────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                     # Slack notifications
DISCORD_WEBHOOK_URL=                   # Discord notifications
