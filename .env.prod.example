# ReconX Production Environment (PostgreSQL, Redis — all values required)
# Store in a secrets manager (Vault, AWS SM, etc.). Never commit this file.

DATABASE_URL=postgresql+psycopg2://reconx:REPLACE_ME@db-prod:5432/reconx
REDIS_URL=redis://:REPLACE_ME_AUTH@redis-prod:6379/0
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
RECONX_SECRET_KEY=REPLACE_ME_production_secret_minimum_32_chars
LOG_LEVEL=INFO
WORKER_POLL_SEC=5
WORKER_MAX_JOBS=4
RECONX_NUCLEI_UPDATE=false
# PostgreSQL container vars (docker compose --profile prod)
POSTGRES_USER=reconx
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=reconx
# CORS (no wildcards in prod)
RECONX_ALLOWED_ORIGINS=https://your-domain.example.com
