# ReconX Development Environment (SQLite, no external services)
# Copy to .env.dev and source before running locally.
# Never commit .env.dev — it is in .gitignore.

DATABASE_URL=sqlite:///./reconx.db
RECONX_SECRET_KEY=dev-insecure-key-replace-before-any-real-use
LOG_LEVEL=DEBUG
WORKER_POLL_SEC=2
WORKER_MAX_JOBS=1
RECONX_NUCLEI_UPDATE=false
