# ==============================================================================
# Technieum .dockerignore — Whitelist approach
# Exclude everything, then include only what the container needs
# ==============================================================================

# Exclude everything by default
*

# --------------- Application code directories ---------------
!app/
!api/
!backend/
!cli/
!config/
!intelligence/
!lib/
!modules/
!parsers/
!scripts/
!bin/
!db/
!tests/

# --------------- Python entry points & config ---------------
!technieum.py
!query.py
!scheduler.py
!event_emitter.py
!state_manager.py
!conftest.py
!config.yaml
!pytest.ini

# --------------- Dependency files ---------------
!requirements.txt
!requirements-api.txt

# --------------- Docker & startup scripts ---------------
!docker-entrypoint.sh
!start.sh
!setup.sh
!install.sh
!install_tools.sh
!kali_setup.sh

# --------------- Re-exclude junk inside included dirs ---------------
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.git/
**/node_modules/
**/.env
**/.env.*
**/*.db
**/*.db-shm
**/*.db-wal
**/*.whl
**/*.log
