# ReconX Staging Environment (PostgreSQL, Redis)
# Copy to .env.staging and fill in values.

DATABASE_URL=postgresql+psycopg2://reconx:REPLACE_ME@db-staging:5432/reconx
REDIS_URL=redis://redis-staging:6379/0
RECONX_SECRET_KEY=REPLACE_ME_staging_key_min_32_chars
LOG_LEVEL=INFO
WORKER_POLL_SEC=5
WORKER_MAX_JOBS=2
RECONX_NUCLEI_UPDATE=false
POSTGRES_USER=reconx
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=reconx
